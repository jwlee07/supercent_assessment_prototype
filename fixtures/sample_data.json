  {"model": "core.mechanic", "pk": 1, "fields": {"name": "뱀 이동 루프", "description": "뱀이 먹이를 먹고 성장하는 핵심 게임플레이 루프. 조작은 스와이프/탭으로 단순화.", "category": "core", "embedding": null, "created_at": "2024-01-10T00:00:00Z"}},
  {"model": "core.mechanic", "pk": 2, "fields": {"name": "배틀로얄 메카닉", "description": "여러 뱀이 동일 맵에서 경쟁, 마지막 생존자 승리. 긴장감 극대화.", "category": "core", "created_at": "2024-01-10T00:00:00Z", "embedding": null}},
  {"model": "core.mechanic", "pk": 3, "fields": {"name": "충돌 시스템", "description": "뱀이 벽이나 다른 뱀의 몸통에 닿으면 죽는 시스템. 전략적 플레이의 핵심.", "category": "core", "created_at": "2024-01-10T00:00:00Z", "embedding": null}},
  {"model": "core.mechanic", "pk": 4, "fields": {"name": "공룡 수집", "description": "다양한 종류의 공룡을 수집하고 업그레이드하는 수집 메카닉.", "category": "collection", "created_at": "2024-01-15T00:00:00Z", "embedding": null}},
  {"model": "core.mechanic", "pk": 5, "fields": {"name": "FTUE (첫 사용자 경험)", "description": "신규 유저가 처음 게임을 접할 때의 튜토리얼 및 온보딩 경험.", "category": "ux", "created_at": "2024-01-15T00:00:00Z", "embedding": null}},
