# Database
# Docker로 PostgreSQL 실행 시 아래 값 그대로 사용 가능
DATABASE_URL=postgresql://postgres:password@localhost:5432/supersuit_ai

# OpenAI API Key
# https://platform.openai.com/api-keys 에서 발급
# gpt-5.4-mini (엔티티 추출 + LLM 응답) 및 text-embedding-3-small (벡터 임베딩) 사용
OPENAI_API_KEY=sk-...

# Naver Cloud CLOVA Speech (음성 업로드 기능 사용 시에만 필요)
# https://www.ncloud.com/product/aiService/clovaSpeech 에서 발급
NAVER_CLOUD_API_KEY=...
NAVER_CLOUD_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt/...
